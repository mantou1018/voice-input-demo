{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": ".tmp/tsc-node"
  },
  "include": [
    "vite.config.ts",
    "src/lib/positionSpeechCorrection.ts",
    "src/lib/resumeAgentService.ts",
    "src/lib/resumeAgentResponse.ts",
    "src/types/speech.ts",
    "src/utils/resumeCard.ts",
    "src/utils/text.ts",
    "src/data/lookupTables.ts",
    "src/data/nameTables.ts",
    "src/data/positionPicker.ts"
  ]
}
